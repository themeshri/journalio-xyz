# Zerion API Key (Server-side only - DO NOT use NEXT_PUBLIC_ prefix)
# Get your API key from https://developers.zerion.io/
ZERION_API_KEY=zk_cff556d473bb4c6f987b48eb9504e562

# Legacy Solana Tracker API Key (Optional - for backward compatibility)
# SOLANA_TRACKER_API_KEY=your-solana-tracker-api-key-here

# Database
# Get from Supabase: Project Settings → Database → Connection String → URI
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.xxx.supabase.co:5432/postgres"

# NextAuth
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Sentry (Error Monitoring)
# Get your DSN from https://sentry.io/
# Optional - only needed for production error tracking
NEXT_PUBLIC_SENTRY_DSN="your-sentry-dsn-here"

