generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id             String         @id @default(cuid())
  name           String?
  email          String?        @unique
  emailVerified  DateTime?
  image          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  accounts       Account[]
  globalRules    GlobalRule[]
  journalEntries JournalEntry[]
  notes          Note[]
  paperedPlays   PaperedPlay[]
  postSessions   PostSession[]
  preSessions    PreSession[]
  sessions       Session[]
  strategies     Strategy[]
  tradeComments  TradeComment[]
  tradeEdits     TradeEdit[]
  settings       UserSettings?
  wallets        Wallet[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String
  address   String
  nickname  String?
  chain     String   @default("ethereum")
  dex       String   @default("other")
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  trades    Trade[]
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, address, chain])
  @@index([address])
  @@index([userId])
  @@index([chain])
  @@index([userId, createdAt])
}

model Trade {
  id           String      @id @default(cuid())
  walletId     String
  signature    String      @unique
  timestamp    Int
  type         String      @default("trade")
  status       String      @default("confirmed")
  direction    String      @default("out")
  chain        String      @default("solana")
  tokenInData  String?
  tokenOutData String?
  amountIn     Float?
  amountOut    Float?
  priceUSD     Float?
  valueUSD     Float       @default(0)
  dex          String      @default("Unknown")
  protocol     String?
  application  String?
  feeData      String?
  createdAt    DateTime    @default(now())
  indexedAt    DateTime    @default(now())
  wallet       Wallet      @relation(fields: [walletId], references: [id], onDelete: Cascade)
  edits        TradeEdit[]

  @@index([walletId])
  @@index([timestamp])
  @@index([signature])
  @@index([chain])
  @@index([type])
  @@index([walletId, timestamp])
  @@index([indexedAt])
}

model TradeEdit {
  id              String   @id @default(cuid())
  tradeId         String
  userId          String
  editedType      String?
  editedAmountIn  Float?
  editedAmountOut Float?
  editedValueUSD  Float?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trade           Trade    @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  @@unique([tradeId, userId])
  @@index([userId])
  @@index([tradeId])
}

model PaperedPlay {
  id                       String    @id @default(cuid())
  userId                   String
  coinName                 String
  contractAddr             String?
  tokenMint                String?
  tokenSymbol              String?
  tokenImage               String?
  mcWhenSaw                String    @default("")
  ath                      String    @default("")
  reasonMissed             String    @default("")
  howToNotMiss             String?
  attachment               String?
  entryPrice               Float?
  entryTime                DateTime?
  exitPrice                Float?
  exitTime                 DateTime?
  hypotheticalPositionSize Float?
  outcome                  String?
  potentialMultiplier      Float?
  potentialPnL             Float?
  peakMultiplier           Float?
  missReason               String?
  strategyId               String?
  rulesMetCount            Int?
  rulesTotalCount          Int?
  notes                    String    @default("")
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  user                     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([missReason])
  @@index([strategyId])
  @@index([userId, createdAt])
}

model UserSettings {
  id               String   @id @default(cuid())
  userId           String   @unique
  displayName      String?
  transactionLimit Int      @default(50)
  showUSDValues    Boolean  @default(true)
  darkMode         Boolean  @default(false)
  timezone         String   @default("UTC")
  tradingStartTime String   @default("09:00")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Strategy {
  id             String   @id @default(cuid())
  userId         String
  name           String
  description    String   @default("")
  color          String   @default("#10b981")
  icon           String   @default("📋")
  ruleGroupsJson String   @default("[]")
  isArchived     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model GlobalRule {
  id        String   @id @default(cuid())
  userId    String
  text      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sortOrder])
}

model PreSession {
  id                  String   @id @default(cuid())
  userId              String
  date                String
  time                String   @default("")
  energyLevel         Int      @default(0)
  emotionalState      String   @default("")
  sessionIntent       String   @default("")
  maxTrades           String   @default("")
  maxLoss             String   @default("")
  timeLimit           String   @default("")
  defaultPositionSize String   @default("")
  hasOpenPositions    Boolean?
  marketSentiment     String   @default("")
  solTrend            String   @default("")
  majorNews           Boolean?
  majorNewsNote       String   @default("")
  normalVolume        Boolean?
  marketSnapshotJson  String   @default("{}")
  rulesCheckedJson    String   @default("[]")
  savedAt             String   @default("")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model JournalEntry {
  id                  String   @id @default(cuid())
  userId              String
  walletAddress       String
  tokenMint           String
  tradeNumber         Int
  strategy            String   @default("")
  strategyId          String?
  ruleResultsJson     String   @default("[]")
  emotionalState      String   @default("")
  buyNotes            String   @default("")
  buyRating           Int      @default(0)
  exitPlan            String   @default("")
  sellRating          Int      @default(0)
  followedExitRule    Boolean?
  sellMistakesJson    String   @default("[]")
  sellNotes           String   @default("")
  attachment          String?
  entryCommentId      String?
  exitCommentId       String?
  managementCommentId String?
  emotionTag          String?
  journaledAt         String   @default("")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  stopLoss            Float?
  takeProfit          Float?
  tradeHigh           Float?
  tradeLow            Float?
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, walletAddress, tokenMint, tradeNumber])
  @@index([userId])
  @@index([walletAddress])
}

model PostSession {
  id              String   @id @default(cuid())
  userId          String
  date            String
  rating          Int      @default(0)
  emotionalState  String   @default("")
  whatWentWell    String   @default("")
  whatWentWrong   String   @default("")
  keyLessons      String   @default("")
  rulesFollowed   Boolean?
  rulesNotes      String   @default("")
  planForTomorrow String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("")
  content   String   @default("")
  tagsJson  String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model TradeComment {
  id        String   @id @default(cuid())
  userId    String
  category  String
  label     String
  rating    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category])
}
