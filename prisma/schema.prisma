// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// NextAuth.js models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  wallets       Wallet[]
  paperedPlays  PaperedPlay[]
  tradeEdits    TradeEdit[]
  settings      UserSettings?
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// User's wallets - now supports multiple chains
model Wallet {
  id        String   @id @default(cuid())
  userId    String
  address   String
  nickname  String?
  chain     String   @default("ethereum") // ethereum, polygon, arbitrum, solana, etc.
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades Trade[]

  @@unique([userId, address, chain])
  @@index([address])
  @@index([userId])
  @@index([chain])
}

// Cached transactions from Zerion API - multichain support
model Trade {
  id         String   @id @default(cuid())
  walletId   String
  signature  String   @unique // Transaction hash/signature
  timestamp  Int
  type       String @default("trade") // send, receive, trade, approve, cancel, deposit, withdraw
  status     String @default("confirmed") // confirmed, pending, failed
  direction  String @default("out") // in, out, self
  chain      String @default("solana") // ethereum, polygon, arbitrum, solana, etc.

  // Token data stored as JSON
  tokenInData  String? // JSON string (optional for non-trade transactions)
  tokenOutData String? // JSON string (optional for non-trade transactions)

  amountIn   Float?
  amountOut  Float?
  priceUSD   Float?
  valueUSD   Float @default(0)
  
  // Protocol/application information (replaces dex field)
  dex        String @default("Unknown") // For backward compatibility
  protocol   String?
  application String?
  
  // Fee information (JSON)
  feeData    String? // JSON string for fee details

  createdAt  DateTime @default(now())
  indexedAt  DateTime @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  edits  TradeEdit[]

  @@index([walletId])
  @@index([timestamp])
  @@index([signature])
  @@index([chain])
  @@index([type])
}

// Trade edits - manual adjustments to trades
model TradeEdit {
  id          String   @id @default(cuid())
  tradeId     String
  userId      String

  // Fields that can be edited
  editedType       String?  // Override buy/sell/swap
  editedAmountIn   Float?   // Override amount in
  editedAmountOut  Float?   // Override amount out
  editedValueUSD   Float?   // Override USD value
  notes            String?  // User notes

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trade Trade @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tradeId, userId])
  @@index([userId])
  @@index([tradeId])
}

// Papered plays - missed opportunities
model PaperedPlay {
  id            String   @id @default(cuid())
  userId        String

  // Token info (existing fields kept for compat)
  coinName      String
  contractAddr  String?
  tokenMint     String?
  tokenSymbol   String?
  tokenImage    String?

  // Legacy fields kept for backward compat
  mcWhenSaw     String   @default("")
  ath           String   @default("")
  reasonMissed  String   @default("")
  howToNotMiss  String?
  attachment    String?

  // Hypothetical trade details
  entryPrice              Float?
  entryTime               DateTime?
  exitPrice               Float?
  exitTime                DateTime?
  hypotheticalPositionSize Float?

  // Outcome tracking
  outcome                 String?   // 'win' | 'loss' | 'breakeven' | 'pending'
  potentialMultiplier     Float?
  potentialPnL            Float?
  peakMultiplier          Float?

  // Why missed
  missReason              String?   // hesitation, distracted, no_capital, risk_limit, late_spotted, low_conviction, sleeping, other

  // Strategy link
  strategyId              String?
  rulesMetCount           Int?
  rulesTotalCount         Int?

  // Meta
  notes                   String    @default("")
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([missReason])
  @@index([strategyId])
}

// User settings
model UserSettings {
  id                String  @id @default(cuid())
  userId            String  @unique
  displayName       String?
  transactionLimit  Int     @default(50)
  showUSDValues     Boolean @default(true)
  darkMode          Boolean @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
