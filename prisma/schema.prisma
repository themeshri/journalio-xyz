// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// NextAuth.js models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  wallets       Wallet[]
  paperedPlays  PaperedPlay[]
  tradeEdits    TradeEdit[]
  settings      UserSettings?
  strategies    Strategy[]
  globalRules   GlobalRule[]
  preSessions   PreSession[]
  journalEntries JournalEntry[]
  tradeComments TradeComment[]
  postSessions  PostSession[]
  notes         Note[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// User's wallets - now supports multiple chains
model Wallet {
  id        String   @id @default(cuid())
  userId    String
  address   String
  nickname  String?
  chain     String   @default("ethereum") // ethereum, polygon, arbitrum, solana, etc.
  dex       String   @default("other")    // fomo, axiom, jupiter, gmgn, other
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades Trade[]

  @@unique([userId, address, chain])
  @@index([address])
  @@index([userId])
  @@index([chain])
  @@index([userId, createdAt])
}

// Cached transactions from Zerion API - multichain support
model Trade {
  id         String   @id @default(cuid())
  walletId   String
  signature  String   @unique // Transaction hash/signature
  timestamp  Int
  type       String @default("trade") // send, receive, trade, approve, cancel, deposit, withdraw
  status     String @default("confirmed") // confirmed, pending, failed
  direction  String @default("out") // in, out, self
  chain      String @default("solana") // ethereum, polygon, arbitrum, solana, etc.

  // Token data stored as JSON
  tokenInData  String? // JSON string (optional for non-trade transactions)
  tokenOutData String? // JSON string (optional for non-trade transactions)

  amountIn   Float?
  amountOut  Float?
  priceUSD   Float?
  valueUSD   Float @default(0)
  
  // Protocol/application information (replaces dex field)
  dex        String @default("Unknown") // For backward compatibility
  protocol   String?
  application String?
  
  // Fee information (JSON)
  feeData    String? // JSON string for fee details

  createdAt  DateTime @default(now())
  indexedAt  DateTime @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  edits  TradeEdit[]

  @@index([walletId])
  @@index([timestamp])
  @@index([signature])
  @@index([chain])
  @@index([type])
  @@index([walletId, timestamp])
  @@index([indexedAt])
}

// Trade edits - manual adjustments to trades
model TradeEdit {
  id          String   @id @default(cuid())
  tradeId     String
  userId      String

  // Fields that can be edited
  editedType       String?  // Override buy/sell/swap
  editedAmountIn   Float?   // Override amount in
  editedAmountOut  Float?   // Override amount out
  editedValueUSD   Float?   // Override USD value
  notes            String?  // User notes

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trade Trade @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tradeId, userId])
  @@index([userId])
  @@index([tradeId])
}

// Papered plays - missed opportunities
model PaperedPlay {
  id            String   @id @default(cuid())
  userId        String

  // Token info (existing fields kept for compat)
  coinName      String
  contractAddr  String?
  tokenMint     String?
  tokenSymbol   String?
  tokenImage    String?

  // Legacy fields kept for backward compat
  mcWhenSaw     String   @default("")
  ath           String   @default("")
  reasonMissed  String   @default("")
  howToNotMiss  String?
  attachment    String?

  // Hypothetical trade details
  entryPrice              Float?
  entryTime               DateTime?
  exitPrice               Float?
  exitTime                DateTime?
  hypotheticalPositionSize Float?

  // Outcome tracking
  outcome                 String?   // 'win' | 'loss' | 'breakeven' | 'pending'
  potentialMultiplier     Float?
  potentialPnL            Float?
  peakMultiplier          Float?

  // Why missed
  missReason              String?   // hesitation, distracted, no_capital, risk_limit, late_spotted, low_conviction, sleeping, other

  // Strategy link
  strategyId              String?
  rulesMetCount           Int?
  rulesTotalCount         Int?

  // Meta
  notes                   String    @default("")
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([missReason])
  @@index([strategyId])
  @@index([userId, createdAt])
}

// User settings
model UserSettings {
  id                String  @id @default(cuid())
  userId            String  @unique
  displayName       String?
  transactionLimit  Int     @default(50)
  showUSDValues     Boolean @default(true)
  darkMode          Boolean @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Phase 3: localStorage → DB Migration Models ───────────────

model Strategy {
  id              String   @id @default(cuid())
  userId          String
  name            String
  description     String   @default("")
  color           String   @default("#10b981")
  icon            String   @default("📋")
  ruleGroupsJson  String   @default("[]") // JSON string of RuleGroup[]
  isArchived      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model GlobalRule {
  id        String   @id @default(cuid())
  userId    String
  text      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sortOrder])
}

model PreSession {
  id                  String   @id @default(cuid())
  userId              String
  date                String   // YYYY-MM-DD
  time                String   @default("")
  energyLevel         Int      @default(0)
  emotionalState      String   @default("")
  sessionIntent       String   @default("")
  maxTrades           String   @default("")
  maxLoss             String   @default("")
  timeLimit           String   @default("")
  defaultPositionSize String   @default("")
  hasOpenPositions    Boolean?
  marketSentiment     String   @default("")
  solTrend            String   @default("")
  majorNews           Boolean?
  majorNewsNote       String   @default("")
  normalVolume        Boolean?
  marketSnapshotJson  String   @default("{}") // JSON string
  rulesCheckedJson    String   @default("[]") // JSON string of rule IDs
  savedAt             String   @default("")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model JournalEntry {
  id               String   @id @default(cuid())
  userId           String
  walletAddress    String
  tokenMint        String
  tradeNumber      Int
  strategy         String   @default("")
  strategyId       String?
  ruleResultsJson  String   @default("[]") // JSON string of TradeRuleResult[]
  emotionalState   String   @default("")
  buyNotes         String   @default("")
  buyRating        Int      @default(0)
  exitPlan         String   @default("")
  sellRating       Int      @default(0)
  followedExitRule Boolean?
  sellMistakesJson String   @default("[]") // JSON string of string[]
  sellNotes        String   @default("")
  attachment       String?  // base64 data URL
  entryCommentId   String?
  exitCommentId    String?
  managementCommentId String?
  emotionTag       String?
  stopLoss         Float?
  takeProfit       Float?
  tradeHigh        Float?
  tradeLow         Float?
  journaledAt      String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, walletAddress, tokenMint, tradeNumber])
  @@index([userId])
  @@index([walletAddress])
}

model PostSession {
  id              String   @id @default(cuid())
  userId          String
  date            String   // YYYY-MM-DD
  rating          Int      @default(0) // 1-10
  emotionalState  String   @default("")
  whatWentWell    String   @default("")
  whatWentWrong   String   @default("")
  keyLessons      String   @default("")
  rulesFollowed   Boolean?
  rulesNotes      String   @default("")
  planForTomorrow String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("")
  content   String   @default("")
  tagsJson  String   @default("[]") // JSON string of string[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model TradeComment {
  id        String   @id @default(cuid())
  userId    String
  category  String   // 'entry' | 'exit' | 'management'
  label     String
  rating    String   // 'positive' | 'neutral' | 'negative'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category])
}
